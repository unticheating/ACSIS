# ── Google OAuth (Google Cloud Console → APIs & Services → Credentials) ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Default sign-in domain when an institution has none set in Institution settings
ALLOWED_EMAIL_DOMAIN=plpasig.edu.ph

# Session signing (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ──
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ── PostgreSQL (optional for local dev; required for real user records) ──
# DATABASE_URL=postgresql://postgres:password@localhost:5432/acsis

# ── Email verification (OTP after Google / password sign-in) ──
# false = sign in immediately (no /verify page). Default: off in development, on in production.
# EMAIL_VERIFICATION_ENABLED=false

# If SMTP is not set, codes are printed in the API terminal (npm run dev:api).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-app-password
# SMTP_FROM=ACSIS <noreply@plpasig.edu.ph>

# ── Administrator email/password (dev only, when DATABASE_URL is not set) ──
# ADMIN_DEV_EMAIL=admin@plpasig.edu.ph
# ADMIN_DEV_PASSWORD=change-me
